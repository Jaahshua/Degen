# Optional. WebSocket endpoint for the OpenSea Stream relay running on
# Railway. When set, TokenDetail (and any other view using
# useOpenSeaStream) receives live item_listed / item_sold / etc events
# instead of relying on the 30s REST poll.
#
# Wire protocol the client expects from the relay:
#   client -> server   { "type": "subscribe",   "slug": "cryptopunks" }
#                       { "type": "unsubscribe", "slug": "cryptopunks" }
#   server -> client    { "event_type": "item_listed",
#                         "payload": { "collection": { "slug": "..." },
#                                       "base_price": "42500000000000000000",
#                                       "payment_token": { "decimals": 18 } } }
#
# Leave unset locally if you don't have the relay deployed; the app
# will keep working off the periodic poll.
NEXT_PUBLIC_STREAM_URL=

# Optional. OpenSea API key. Unlocks higher rate limits + endpoints
# (collection list, per-wallet holdings, transfer history) that we
# need for real Bubble Map data.
NEXT_PUBLIC_OPENSEA_API_KEY=

# Optional. WalletConnect Cloud project ID. RainbowKit will use a
# fallback project string if this isn't set, but you'll get a
# console warning and degraded mobile WalletConnect UX.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
